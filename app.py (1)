                                return '<mark class="search-highlight">' + m + '</mark>';
                            }});

                            if (!firstMatch) {{
                                firstMatch = span.querySelector("mark");
                            }}

                            node.parentNode.replaceChild(span, node);
                        }}
                    }});

                    document.getElementById("matchCount_{idx}").innerText =
                        count > 0 ? count + " matches found" : "No matches";

                    if (firstMatch) {{
                        firstMatch.scrollIntoView({{
                            behavior: "smooth",
                            block: "center"
                        }});
                    }}

                }});

