def download_pdf(text):
    bio = BytesIO()
    c = canvas.Canvas(bio, pagesize=LETTER)
    y = 750
    for line in text.split("\n"):
        if y < 60:
            c.showPage()
            y = 750
        c.drawString(40, y, line[:90])
        y -= 14
    c.save()
    bio.seek(0)
    return bio

