                    st.session_state["video_summaries"][video["name"]] = "No transcript available."
                    continue

                plain_text = " ".join([s["text"].strip() for s in segments if s.get("text")])
                chunks = chunk_text(plain_text)

                # --- MODEL PROMPT HANDLING ---
                prefix = "summarize: " if "flan" in selected_model_path.lower() else ""

                current_summaries = []
                for chunk in chunks:
                    inputs = tokenizer(prefix + chunk, return_tensors="pt", truncation=True, max_length=512).to(device)

                    summary_ids = model.generate(
                        inputs["input_ids"],
                        max_length=summary_length,
                        min_length=int(summary_length * 0.4),
                        num_beams=4,
                        length_penalty=2.0,
                        early_stopping=True
                    )
                    current_summaries.append(tokenizer.decode(summary_ids[0], skip_special_tokens=True))

                # Final Pass
                combined_text = " ".join(current_summaries)
                inputs = tokenizer(prefix + combined_text, return_tensors="pt", truncation=True, max_length=512).to(device)

                final_ids = model.generate(
                    inputs["input_ids"],
                    max_length=summary_length,
                    min_length=int(summary_length * 0.4),
                    num_beams=4
                )
                st.session_state["video_summaries"][video["name"]] = tokenizer.decode(final_ids[0], skip_special_tokens=True)

            progress.progress((i + 1) / len(video_results))
        st.success(f"Summaries generated using {selected_display_name}!")

