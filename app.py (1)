def highlight_threats(text):
    # 1. Get all threats and sort by length (longest first)
    # This prevents partial highlighting if one threat word is inside another
    all_threats = sorted(
        list(THREAT_WORDS.union(st.session_state["custom_threat_words"])),
        key=len,
        reverse=True
    )

    if not all_threats:
        return text

    # 2. Escape words to handle special characters and join them into a pattern
    # We use a pattern that works across different languages
    pattern = "|".join(re.escape(word) for word in all_threats)

    # 3. Use a Case-Insensitive replacement
    # We don't use \b here because Hindi/Arabic/etc. don't always trigger it correctly
    def replace_func(match):
        return f"<span class='threat-word'>{match.group(0)}</span>"

    # Use re.IGNORECASE for English words; Hindi is unaffected by case
    highlighted_text = re.sub(f"({pattern})", replace_func, text, flags=re.IGNORECASE)

    return highlighted_text

def highlight_search(text, query):
    if not query:
        return text
    terms = [t.strip() for t in query.split(",")]
    html = text
    for term in terms:
        if term:
            pattern = rf"\b{re.escape(term)}\b"
            html = re.sub(pattern, r'<span class="search-highlight">\g<0></span>', html, flags=re.IGNORECASE)
    return html

