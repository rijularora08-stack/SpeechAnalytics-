def extract_audio(video_path, audio_path):
    audio = AudioSegment.from_file(video_path)
    audio.set_frame_rate(16000).set_channels(1).export(audio_path, format="wav")

def extract_audio_segment(audio_path, start, end):
    audio = AudioSegment.from_wav(audio_path)
    segment = audio[start * 1000 : end * 1000]
    bio = BytesIO()
    segment.export(bio, format="wav")
    bio.seek(0)
    return bio

def extract_fixed_video_segment(video_path, start, duration=10):
    out = BytesIO()
    cmd = [
        "ffmpeg", "-y",
        "-ss", str(start),
        "-t", str(duration),
        "-i", video_path,
        "-c", "copy",
        "-movflags", "frag_keyframe+empty_moov",
        "pipe:1"
    ]
    process = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL)
    out.write(process.stdout.read())
    process.wait()
    out.seek(0)
    return out


